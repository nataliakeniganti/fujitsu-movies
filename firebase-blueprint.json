{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "displayName": { "type": "string", "description": "User's display name." },
        "photoURL": { "type": "string", "description": "User's profile photo URL." },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User's role in the application." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user profile was created." }
      },
      "required": ["uid", "email", "role"]
    },
    "Bookmark": {
      "title": "Bookmark",
      "description": "A movie bookmarked by a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who bookmarked the movie." },
        "movieTitle": { "type": "string", "description": "The title of the bookmarked movie." },
        "movieYear": { "type": "string", "description": "The year of the bookmarked movie." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the bookmark was created." }
      },
      "required": ["userId", "movieTitle"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles."
    },
    "/users/{userId}/bookmarks/{bookmarkId}": {
      "schema": "Bookmark",
      "description": "Subcollection of movie bookmarks for each user."
    }
  }
}
